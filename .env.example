# API Configuration
# Set to false to use a remote API instead of local JSON data
VITE_USE_LOCAL_DATA=true

# Remote API base URL (used when VITE_USE_LOCAL_DATA is false)
VITE_API_URL=http://localhost:3000

# Example with a production API:
# VITE_API_URL=https://api.example.com
# VITE_USE_LOCAL_DATA=false
